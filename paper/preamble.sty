% preamble.sty -- Notation macros and formatting for the self-modeling paper
% ASSERT_CONVENTION: natural_units=N/A, metric_signature=N/A, fourier_convention=N/A,
%   coupling_convention=N/A, renormalization_scheme=N/A, gauge_choice=N/A
% CUSTOM_CONVENTION: sequential_product=a.b (dot notation), jordan_product=a circ b,
%   compression=C_p, axiom_source=arXiv:1803.11139 Definition 2 EXCLUSIVELY

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{preamble}[2026/03/21 Self-modeling paper macros]

% --- Core packages ---
\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{amsthm}
\RequirePackage{mathtools}
\RequirePackage{hyperref}
\RequirePackage{cleveref}
\RequirePackage{enumitem}
\RequirePackage{booktabs}
\RequirePackage{array}

% --- Theorem environments ---
\newtheorem{theorem}{Theorem}[section]
\newtheorem{lemma}[theorem]{Lemma}
\newtheorem{proposition}[theorem]{Proposition}
\newtheorem{corollary}[theorem]{Corollary}

\theoremstyle{definition}
\newtheorem{definition}[theorem]{Definition}
\newtheorem{assumption}[theorem]{Assumption}
\newtheorem{example}[theorem]{Example}

\theoremstyle{remark}
\newtheorem{remark}[theorem]{Remark}

% --- Notation macros ---

% Sequential product: a . b  (dot notation, matching vdW published convention)
% Usage: \sp{a}{b} renders as a \cdot b
\newcommand{\sp}[2]{#1 \mathbin{\cdot} #2}

% Jordan product: a o b = (1/2)(a . b + b . a)
% Usage: \jp{a}{b} renders as a \circ b
\newcommand{\jp}[2]{#1 \circ #2}

% Compression: C_p
% Usage: \comp{p} renders as C_p
\newcommand{\comp}[1]{C_{#1}}

% Peirce projection: P_{ij}
% Usage: \peirce{ij} renders as P_{ij}
\newcommand{\peirce}[1]{P_{#1}}

% Effect space: [0,1]_V
% Usage: \eff{V} renders as [0,1]_V
\newcommand{\eff}[1]{[0,1]_{#1}}

% Order unit space (text macro)
\newcommand{\ous}{\textnormal{OUS}}

% Euclidean Jordan algebra (text macro)
\newcommand{\eja}{\textnormal{EJA}}

% Self-adjoint part: A^{sa}
\newcommand{\sa}{^{\mathrm{sa}}}

% Normalized trace functional
\newcommand{\tr}{\tau}

% Identity element
\newcommand{\id}{\mathbb{1}}

% Orthogonality symbol (already defined in LaTeX as \perp)
% We use \perp directly; no redefinition needed.

% Compatibility
\newcommand{\comp@tible}{\mathrel{\mid}}
\newcommand{\compatible}{\comp@tible}

% Face generated by p
\newcommand{\face}[1]{\mathrm{face}(#1)}

% Pinching map
\newcommand{\pinch}{\mathrm{pinch}}

% Projection (projective unit)
\newcommand{\Proj}{\mathrm{Proj}}

% Span
\newcommand{\spn}{\mathrm{span}}

% Dimension
\newcommand{\dm}{\dim}

% Shorthand for M_n(C)^sa
\newcommand{\Mnsa}[1]{M_{#1}(\mathbb{C})\sa}

% Shorthand for M_n(K)^sa for general K
\newcommand{\MnKsa}[2]{M_{#1}(#2)\sa}

% Spin factor
\newcommand{\spinfactor}[1]{V_{#1}}

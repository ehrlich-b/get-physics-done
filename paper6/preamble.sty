% preamble.sty — Custom macros for Paper 6: Spacetime from Self-Modeling
% ASSERT_CONVENTION: natural_units=natural, metric_signature=mostly_plus, entropy_base=nats, modular_hamiltonian=K_minus_ln_rho, coupling_convention=H_sum_hxy, state_normalization=Tr_rho_1

% ————————————————————————————————————
% Packages
% ————————————————————————————————————
\usepackage{amsmath,amssymb,amsthm}
\usepackage{mathtools}
\usepackage{bbm}
\usepackage{booktabs}
\usepackage{graphicx}
\usepackage{hyperref}
\usepackage{xcolor}

% ————————————————————————————————————
% Metric and curvature — signature (-,+,+,+)
% ————————————————————————————————————
\newcommand{\gab}{g_{ab}}
\newcommand{\Gab}{G_{ab}}
\newcommand{\Rab}{R_{ab}}
\newcommand{\Tab}{T_{ab}}
\newcommand{\Rabcd}{R_{abcd}}

% ————————————————————————————————————
% Entanglement and modular quantities
% ————————————————————————————————————
\newcommand{\ent}{S}                       % von Neumann entropy
\newcommand{\modH}{K_A}                    % modular Hamiltonian K_A = -ln(rho_A)
\newcommand{\rhoA}{\rho_A}                 % reduced density matrix

% ————————————————————————————————————
% Self-modeling quantities
% ————————————————————————————————————
\newcommand{\SM}{self-modeling}             % inline text
\newcommand{\swapop}{F_{xy}}               % SWAP operator
\newcommand{\vlr}{v_{\mathrm{LR}}}         % Lieb-Robinson velocity
\newcommand{\Gnewton}{G}                   % Newton's constant G = 1/(4 eta)

% ————————————————————————————————————
% Standard math shortcuts
% ————————————————————————————————————
\DeclarePairedDelimiter{\abs}{\lvert}{\rvert}
\DeclarePairedDelimiter{\norm}{\lVert}{\rVert}
\newcommand{\bra}[1]{\langle #1 |}
\newcommand{\ket}[1]{| #1 \rangle}
\newcommand{\braket}[2]{\langle #1 | #2 \rangle}
\newcommand{\expval}[1]{\langle #1 \rangle}
\DeclareMathOperator{\Tr}{Tr}
\DeclareMathOperator{\rank}{rank}
\newcommand{\1}{\mathbbm{1}}               % identity operator

% ————————————————————————————————————
% Theorem environments
% ————————————————————————————————————
\newtheorem{theorem}{Theorem}
\newtheorem{lemma}[theorem]{Lemma}
\newtheorem{proposition}[theorem]{Proposition}
\newtheorem{corollary}[theorem]{Corollary}
\theoremstyle{definition}
\newtheorem{definition}[theorem]{Definition}
\theoremstyle{remark}
\newtheorem{remark}[theorem]{Remark}

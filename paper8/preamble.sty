% ————————————————————————————————————
% Thermodynamics / information macros (new for Paper 8)
% ————————————————————————————————————
\newcommand{\kB}{k_{\mathrm{B}}}                              % Boltzmann constant
\newcommand{\MI}[2]{I(#1;#2)}                                 % mutual information I(B;M)
\newcommand{\SvN}[1]{S_{\mathrm{vN}}(#1)}                     % von Neumann entropy
\newcommand{\rhoexp}{\rho}                                     % experiential density
\newcommand{\Smax}{S_{\max}}                                   % maximum entropy
\newcommand{\Wmin}{W_{\min}}                                   % minimum work
\newcommand{\tauex}{\tau_{\mathrm{exhaust}}}                   % exhaustion timescale
\newcommand{\tcyc}{t_{\mathrm{cycle}}}                         % cycle time
\DeclareMathOperator{\diag}{diag}

% ————————————————————————————————————
% Clifford algebra macros (carried from Paper 7)
% ————————————————————————————————————
\newcommand{\Cl}[1]{\mathrm{Cl}(#1)}                          % Cl(n)
\newcommand{\omegasix}{\omega_6}                               % Cl(6) volume form
\newcommand{\Gammastar}{\Gamma_*}                              % chirality operator

% ————————————————————————————————————
% Group macros (carried from Paper 7)
% ————————————————————————————————————
\newcommand{\Spin}[1]{\mathrm{Spin}(#1)}
\newcommand{\SU}[1]{\mathrm{SU}(#1)}
\newcommand{\SO}[1]{\mathrm{SO}(#1)}
\newcommand{\UU}[1]{\mathrm{U}(#1)}
\newcommand{\Ffour}{F_4}
\newcommand{\Esix}{E_6}

% ————————————————————————————————————
% Standard Model macros (carried from Paper 7)
% ————————————————————————————————————
\newcommand{\SMgauge}{\SU{3}_C \times \SU{2}_L \times \UU{1}_Y}
\newcommand{\PS}{\SU{4} \times \SU{2}_L \times \SU{2}_R}
\newcommand{\rep}[1]{\mathbf{#1}}

% ————————————————————————————————————
% Jordan algebra macros (carried from Paper 7)
% ————————————————————————————————————
\newcommand{\hthree}{h_3(\mathbb{O})}
\newcommand{\Vhalf}{V_{1/2}}

% ————————————————————————————————————
% Standard math shortcuts
% ————————————————————————————————————
\DeclarePairedDelimiter{\abs}{\lvert}{\rvert}
\DeclarePairedDelimiter{\norm}{\lVert}{\rVert}
\newcommand{\bra}[1]{\langle #1 |}
\newcommand{\ket}[1]{| #1 \rangle}
\newcommand{\braket}[2]{\langle #1 | #2 \rangle}
\newcommand{\expval}[1]{\langle #1 \rangle}
\DeclareMathOperator{\Tr}{Tr}
\newcommand{\1}{\mathds{1}}

% ————————————————————————————————————
% Theorem environments
% ————————————————————————————————————
\newtheorem{theorem}{Theorem}
\newtheorem{lemma}[theorem]{Lemma}
\newtheorem{proposition}[theorem]{Proposition}
\newtheorem{corollary}[theorem]{Corollary}
\theoremstyle{definition}
\newtheorem{definition}[theorem]{Definition}
\theoremstyle{remark}
\newtheorem{remark}[theorem]{Remark}
